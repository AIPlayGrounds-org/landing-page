---
/**
 * index.astro - Página principal de AI PlayGrounds
 *
 * Single-page landing con scroll continuo.
 * Cada sección tiene su propio id para navegación interna.
 *
 * Estructura (12 bloques en orden):
 * 1. Header (sticky nav)
 * 2. Hero (propuesta de valor + partículas)
 * 3. Métricas (impacto con counters animados)
 * 4. Programas (3 cards educativos)
 * 5. Casos de Éxito (proyectos desplegados)
 * 6. Testimonios (carrusel)
 * 7. Equipo (8 miembros)
 * 8. Eventos (timeline + countdown)
 * 9. Partners (28 logos marquee)
 * 10. Advisors (2 cards)
 * 11. CTA + FAQ (accordion)
 * 12. Footer
 */

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Metrics from '../components/Metrics.astro';
import Programs from '../components/Programs.astro';
import CaseStudies from '../components/CaseStudies.astro';
import Testimonials from '../components/Testimonials.astro';
import Team from '../components/Team.astro';
import Events from '../components/Events.astro';
import Partners from '../components/Partners.astro';
import Advisors from '../components/Advisors.astro';
import CtaFaq from '../components/CtaFaq.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <!-- Navegación sticky -->
  <Header />

  <main>
    <!-- Hero: Propuesta de valor con texto rotativo -->
    <Hero />

    <!-- Métricas: Social proof con números animados -->
    <Metrics />

    <!-- Programas: Los 3 programas educativos -->
    <Programs />

    <!-- Casos de Éxito: Proyectos construidos por participantes -->
    <CaseStudies />

    <!-- Testimonios: Voces de la comunidad -->
    <Testimonials />

    <!-- Equipo: Las personas detrás de AI PlayGrounds -->
    <Team />

    <!-- Eventos: Timeline 2026 + Hack@LATAM countdown -->
    <Events />

    <!-- Partners: 28 logos en marquee infinito -->
    <Partners />

    <!-- Advisors: Boris y Jeslyn -->
    <Advisors />

    <!-- CTA Final + FAQ: Conversión y preguntas frecuentes -->
    <CtaFaq />
  </main>

  <!-- Footer: Links y redes sociales -->
  <Footer />
</Layout>
