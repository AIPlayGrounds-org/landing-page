---
/**
 * Team.astro - Equipo de AI PlayGrounds
 *
 * Características:
 * - Grid de 8 miembros del equipo
 * - Fotos reales (placeholder con iniciales si no hay imagen)
 * - Nombre, cargo y link a LinkedIn
 * - Soledad destacada como founder/PM
 */

// Datos del equipo
const team = [
  {
    name: 'Soledad Ñahui',
    role: 'Project Manager',
    image: '/images/team/soledad.jpg',
    linkedin: '#',
    featured: true, // Destacada como founder/PM
  },
  {
    name: 'Andrea',
    role: 'Diseño y Arte',
    image: '/images/team/andrea.jpg',
    linkedin: '#',
  },
  {
    name: 'Jhonatan Morgan',
    role: 'ML Engineer',
    image: '/images/team/jhonatan.jpg',
    linkedin: '#',
  },
  {
    name: 'Rocío Laura',
    role: 'Automatización',
    image: '/images/team/rocio.jpg',
    linkedin: '#',
  },
  {
    name: 'Diego',
    role: 'Software Engineer',
    image: '/images/team/diego.jpg',
    linkedin: '#',
  },
  {
    name: 'Joseph',
    role: 'Telecommunications Engineer',
    image: '/images/team/joseph.jpg',
    linkedin: '#',
  },
  {
    name: 'Ana',
    role: 'Automation',
    image: '/images/team/ana.jpg',
    linkedin: '#',
  },
  {
    name: 'Max',
    role: 'Software Engineer',
    image: '/images/team/max.jpg',
    linkedin: '#',
  },
];

// Función para obtener iniciales
function getInitials(name: string): string {
  return name.split(' ').map(n => n[0]).join('').toUpperCase();
}
---

<section id="equipo" class="py-16 sm:py-20 lg:py-24 bg-bg-primary">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header de sección -->
    <div class="text-center mb-12 lg:mb-16 reveal">
      <h2 class="section-title">El equipo detrás de AI PlayGrounds</h2>
      <div class="section-divider mx-auto"></div>
      <p class="section-subtitle mx-auto">
        Personas reales construyendo el futuro de la educación en IA desde Latinoamérica.
      </p>
    </div>

    <!-- Grid del equipo -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 reveal-stagger">
      {team.map((member) => (
        <div
          class={`card p-6 text-center group ${member.featured ? 'border-electric-indigo' : ''}`}
        >
          <!-- Foto / Avatar -->
          <div class="relative mx-auto mb-4">
            <div
              class={`w-24 h-24 rounded-full mx-auto flex items-center justify-center text-2xl font-bold font-display
                ${member.featured
                  ? 'bg-electric-indigo/20 text-electric-indigo border-2 border-electric-indigo'
                  : 'bg-bg-elevated text-text-secondary border-2 border-border-subtle group-hover:border-neon-cyan'
                }
                transition-all duration-300`}
            >
              {/* Placeholder con iniciales - reemplazar con imagen real */}
              <span>{getInitials(member.name)}</span>
            </div>

            {/* Badge de featured */}
            {member.featured && (
              <div class="absolute -top-1 -right-1 w-6 h-6 bg-electric-indigo rounded-full flex items-center justify-center">
                <svg class="w-3 h-3 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
              </div>
            )}
          </div>

          <!-- Nombre -->
          <h3 class="text-lg font-bold font-display text-text-primary mb-1">
            {member.name}
          </h3>

          <!-- Rol -->
          <p class="text-text-secondary text-sm mb-4">
            {member.role}
          </p>

          <!-- LinkedIn -->
          <a
            href={member.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center w-8 h-8 rounded-full bg-bg-elevated border border-border-subtle hover:border-electric-indigo hover:bg-electric-indigo/10 transition-all"
            aria-label={`LinkedIn de ${member.name}`}
          >
            <svg class="w-4 h-4 text-text-secondary hover:text-electric-indigo" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
