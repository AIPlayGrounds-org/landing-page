---
/**
 * Hero.astro - Sección hero de AI PlayGrounds
 *
 * Características:
 * - Texto rotativo animado cada 3 segundos
 * - Fondo con partículas (tsParticles) lazy-loaded
 * - 2 CTAs: primario (Electric Indigo) y secundario (Neon Cyan outline)
 * - Ocupa 100vh (pantalla completa)
 */

// Textos que rotan en el headline
const rotatingTexts = [
  'Comprende IA.',
  'Construye con IA.',
  'Lidera con IA.',
];
---

<section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden">

  <!-- Contenedor de partículas (se inicializa con JS) -->
  <div id="tsparticles" class="absolute inset-0 z-0"></div>

  <!-- Fallback gradient background (visible hasta que carguen las partículas) -->
  <div class="absolute inset-0 z-0">
    <!-- Gradientes decorativos -->
    <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-electric-indigo/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-neon-cyan/10 rounded-full blur-3xl"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-electric-indigo/5 rounded-full blur-3xl"></div>
  </div>

  <!-- Contenido principal -->
  <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">

    <!-- Texto rotativo -->
    <div class="mb-6">
      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold font-display text-text-primary leading-tight">
        <span id="rotating-text" class="inline-block min-w-[280px] sm:min-w-[400px]">
          {rotatingTexts[0]}
        </span>
      </h1>
    </div>

    <!-- Subtítulo fijo -->
    <p class="text-lg sm:text-xl md:text-2xl text-text-secondary max-w-3xl mx-auto mb-10 leading-relaxed">
      La comunidad de educación en inteligencia artificial más grande de <span class="text-neon-cyan">Latinoamérica</span>
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-6">
      <!-- CTA Principal -->
      <a
        href="#programas"
        class="btn-primary text-lg px-8 py-4 w-full sm:w-auto"
      >
        Empieza gratis
      </a>

      <!-- CTA Secundario -->
      <a
        href="#eventos"
        class="btn-secondary text-lg px-8 py-4 w-full sm:w-auto"
      >
        Ver Hack@LATAM 2026
      </a>
    </div>

    <!-- Indicador de scroll -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
      <svg class="w-6 h-6 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </div>
  </div>
</section>

<!-- Estilos específicos del Hero -->
<style>
  /* Animación de fade para el texto rotativo */
  @keyframes text-fade-in {
    0% {
      opacity: 0;
      transform: translateY(20px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes text-fade-out {
    0% {
      opacity: 1;
      transform: translateY(0);
    }
    100% {
      opacity: 0;
      transform: translateY(-20px);
    }
  }

  .text-entering {
    animation: text-fade-in 0.5s ease forwards;
  }

  .text-exiting {
    animation: text-fade-out 0.5s ease forwards;
  }

  /* Estilo para partículas cargadas */
  #tsparticles canvas {
    position: absolute !important;
  }
</style>

<!-- Script para texto rotativo y partículas -->
<script>
  // ═══════════════════════════════════════════════════════════
  // TEXTO ROTATIVO
  // ═══════════════════════════════════════════════════════════
  const rotatingTexts = [
    'Comprende IA.',
    'Construye con IA.',
    'Lidera con IA.',
  ];

  let currentIndex = 0;
  const textElement = document.getElementById('rotating-text');

  function rotateText() {
    if (!textElement) return;

    // Fade out
    textElement.classList.remove('text-entering');
    textElement.classList.add('text-exiting');

    setTimeout(() => {
      // Cambiar texto
      currentIndex = (currentIndex + 1) % rotatingTexts.length;
      textElement.textContent = rotatingTexts[currentIndex];

      // Fade in
      textElement.classList.remove('text-exiting');
      textElement.classList.add('text-entering');
    }, 500);
  }

  // Iniciar rotación cada 3 segundos
  setInterval(rotateText, 3000);

  // ═══════════════════════════════════════════════════════════
  // TSPARTICLES - Lazy loaded
  // ═══════════════════════════════════════════════════════════
  async function initParticles() {
    // Verificar si tsParticles está disponible
    if (typeof window !== 'undefined' && 'tsParticles' in window) {
      const { tsParticles } = window as any;

      await tsParticles.load('tsparticles', {
        fullScreen: false,
        background: {
          color: 'transparent',
        },
        fpsLimit: 60,
        particles: {
          number: {
            value: 80,
            density: {
              enable: true,
              area: 800,
            },
          },
          color: {
            value: ['#6366F1', '#22D3EE'], // Electric Indigo y Neon Cyan
          },
          shape: {
            type: 'circle',
          },
          opacity: {
            value: 0.5,
            random: true,
          },
          size: {
            value: { min: 1, max: 3 },
          },
          move: {
            enable: true,
            speed: 1,
            direction: 'none',
            random: true,
            straight: false,
            outModes: {
              default: 'out',
            },
          },
          links: {
            enable: true,
            distance: 150,
            color: '#6366F1',
            opacity: 0.2,
            width: 1,
          },
        },
        interactivity: {
          events: {
            onHover: {
              enable: true,
              mode: 'grab',
            },
            resize: true,
          },
          modes: {
            grab: {
              distance: 140,
              links: {
                opacity: 0.5,
              },
            },
          },
        },
        detectRetina: true,
      });
    }
  }

  // Intentar inicializar las partículas
  // Si tsParticles no está cargado, el fallback gradient se muestra
  if (document.readyState === 'complete') {
    initParticles();
  } else {
    window.addEventListener('load', initParticles);
  }
</script>
