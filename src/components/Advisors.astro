---
/**
 * Advisors.astro - Advisors de la comunidad AI PlayGrounds
 *
 * Características:
 * - 2 cards de advisor lado a lado
 * - Foto grande circular, nombre, cargo, empresa
 * - Breve bio y link a LinkedIn
 * - Visualmente diferenciada de Partners (personas, no logos)
 */

// Datos de advisors
const advisors = [
  {
    name: 'Boris',
    company: 'Intercorp',
    role: 'Executive Leader',
    bio: 'Líder ejecutivo con amplia experiencia en transformación digital. Apoya a AI PlayGrounds en la estrategia de crecimiento y conexiones corporativas.',
    linkedin: '#',
    image: '/images/advisors/boris.jpg',
  },
  {
    name: 'Jeslyn',
    company: 'Amazon',
    role: 'Tech Lead',
    bio: 'Tech Lead en Amazon con expertise en sistemas distribuidos e IA. Asesora en el diseño curricular y estándares técnicos de los programas.',
    linkedin: '#',
    image: '/images/advisors/jeslyn.jpg',
  },
];
---

<section id="advisors" class="py-16 sm:py-20 lg:py-24 bg-bg-primary">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header de sección -->
    <div class="text-center mb-12 lg:mb-16 reveal">
      <h2 class="section-title">Nuestros Advisors</h2>
      <div class="section-divider mx-auto"></div>
      <p class="section-subtitle mx-auto">
        Líderes de la industria que creen en nuestra misión y nos guían para llegar más lejos.
      </p>
    </div>

    <!-- Grid de advisors -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 reveal-stagger">
      {advisors.map((advisor) => (
        <div class="card p-8 text-center group hover:border-electric-indigo">

          <!-- Foto circular -->
          <div class="relative mx-auto mb-6">
            <div class="w-28 h-28 lg:w-32 lg:h-32 rounded-full mx-auto bg-bg-elevated border-2 border-border-subtle group-hover:border-electric-indigo transition-all duration-300 flex items-center justify-center">
              {/* Placeholder con iniciales - reemplazar con imagen real */}
              <span class="text-3xl font-bold font-display text-text-secondary">
                {advisor.name[0]}
              </span>
            </div>

            {/* Glow en hover */}
            <div class="absolute inset-0 rounded-full bg-electric-indigo/20 blur-xl opacity-0 group-hover:opacity-100 transition-opacity duration-300 -z-10"></div>
          </div>

          <!-- Nombre -->
          <h3 class="text-xl lg:text-2xl font-bold font-display text-text-primary mb-1">
            {advisor.name}
          </h3>

          <!-- Cargo y empresa -->
          <p class="text-electric-indigo font-medium mb-1">
            {advisor.role}
          </p>
          <p class="text-text-muted text-sm mb-4">
            {advisor.company}
          </p>

          <!-- Bio -->
          <p class="text-text-secondary text-sm leading-relaxed mb-6">
            {advisor.bio}
          </p>

          <!-- LinkedIn -->
          <a
            href={advisor.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-text-secondary hover:text-electric-indigo transition-colors"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
            <span class="text-sm font-medium">Ver perfil</span>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
